# ─────────────────────────────────────────────────────────────
# LifeLink / MediConnect — Backend Environment Template
# Copy this file to .env and fill in your values.
# AI Provider: Groq (exclusively — no Gemini)
# ─────────────────────────────────────────────────────────────

# Application Settings
ENVIRONMENT=development
DEBUG=True
API_V1_STR=/api/v1
PROJECT_NAME="SmartAid"

# ── Groq API Key (required) ────────────────────────────────────
# Get yours at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Model Configuration ────────────────────────────────────────
# Single model for vision + chat
VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
CHAT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXP_SECONDS=86400

# ── MongoDB ────────────────────────────────────────────────────
MONGO_URI=your_mongodb_connection_string_here
MONGODB_URI=your_mongodb_connection_string_here
MONGODB_DB_NAME=smartaid_db
MONGODB_MIN_POOL_SIZE=10
MONGODB_MAX_POOL_SIZE=100

# ── Flask (legacy, kept for compatibility) ─────────────────────
FLASK_ENV=development
FLASK_DEBUG=1

# CORS Configuration
CORS_ORIGINS=["*"]
