# ─────────────────────────────────────────────────────────────
# LifeLink / MediConnect — Backend Environment Template
# Copy this file to .env and fill in your values.
# AI Providers: Google Gemini and Sarvam AI
# ─────────────────────────────────────────────────────────────

# Application Settings
ENVIRONMENT=development
DEBUG=True
API_V1_STR=/api/v1
PROJECT_NAME="SmartAid"

# ── Google Gemini API Key (required) ───────────────────────────
# Get yours at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── Sarvam AI API Key (required for TTS/STT/Translate) ───────────
# Get yours at: https://dashboard.sarvam.ai/
SARVAM_API_KEY=your_sarvam_api_key_here

# ── Model Configuration ────────────────────────────────────────
GEMINI_MODEL=gemini-1.5-flash

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXP_SECONDS=86400

# ── MongoDB ────────────────────────────────────────────────────
MONGO_URI=your_mongodb_connection_string_here
MONGODB_URI=your_mongodb_connection_string_here
MONGODB_DB_NAME=smartaid_db
MONGODB_MIN_POOL_SIZE=10
MONGODB_MAX_POOL_SIZE=100

# ── Flask (legacy, kept for compatibility) ─────────────────────
FLASK_ENV=development
FLASK_DEBUG=1

# CORS Configuration
CORS_ORIGINS=["*"]
